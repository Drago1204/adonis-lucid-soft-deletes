{
  "name": "adonis-lucid-soft-deletes",
  "description": "Addon for soft deletes AdonisJS Lucid ORM",
  "version": "2.1.0",
  "engines": {
    "node": ">=20.6.0"
  },
  "main": "./build/index.js",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types/*": "./build/src/types/*.js",
    "./bindings": "./build/src/bindings/model_query_builder.js",
    "./provider": "./build/providers/lucid_soft_deletes_provider.js"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "clean": "del-cli build",
    "precompile": "pnpm run lint && pnpm run clean",
    "compile": "tsup-node && tsc --emitDeclarationOnly --declaration",
    "build": "pnpm run compile",
    "quick:test": "NODE_DEBUG=\"adonis-lucid-soft-deletes\" node --enable-source-maps --loader=ts-node/esm bin/test.ts",
    "pretest": "pnpm run lint",
    "test": "c8 pnpm run quick:test",
    "typecheck": "tsc --noEmit",
    "version": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "release": "np"
  },
  "devDependencies": {
    "@adonisjs/assembler": "8.4.0",
    "@adonisjs/core": "7.3.4",
    "@adonisjs/eslint-config": "3.1.0",
    "@adonisjs/prettier-config": "1.5.0",
    "@adonisjs/tsconfig": "2.0.0",
    "@dirupt/adonis-lucid-filter": "6.0.2",
    "@japa/assert": "4.2.0",
    "@japa/expect-type": "2.0.4",
    "@japa/file-system": "3.0.0",
    "@japa/runner": "5.3.0",
    "@japa/snapshot": "2.0.10",
    "@poppinss/hooks": "7.3.0",
    "@swc/core": "1.15.4",
    "@types/lodash": "4.17.24",
    "@types/luxon": "3.7.1",
    "@types/node": "25.9.2",
    "c8": "11.0.0",
    "copyfiles": "2.4.1",
    "del-cli": "7.0.0",
    "eslint": "10.4.1",
    "knex": "3.2.10",
    "lodash": "4.18.1",
    "luxon": "3.7.2",
    "np": "11.2.1",
    "reflect-metadata": "0.2.2",
    "sqlite3": "6.0.1",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@adonisjs/core": "7.3.4",
    "@adonisjs/lucid": "22.4.2"
  },
  "author": "LookinGit",
  "license": "MIT",
  "homepage": "https://github.com/lookinlab/adonis-lucid-soft-deletes#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/lookinlab/adonis-lucid-soft-deletes.git"
  },
  "bugs": {
    "url": "https://github.com/lookinlab/adonis-lucid-soft-deletes/issues"
  },
  "keywords": [
    "adonisjs",
    "adonisjs-lucid",
    "adonisjs-lucid-soft-deletes",
    "adonisjs-soft-deletes",
    "adonis",
    "adonis-lucid",
    "adonis-lucid-soft-deletes",
    "adonis-soft-deletes"
  ],
  "prettier": "@adonisjs/prettier-config",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "np": {
    "message": "chore(release): %s",
    "tag": "latest",
    "branch": "master",
    "anyBranch": false
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**",
      "bin/**"
    ]
  },
  "tsup": {
    "entry": [
      "./index.ts",
      "./src/types/*.ts",
      "./src/bindings/model_query_builder.ts",
      "./providers/lucid_soft_deletes_provider.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": false,
    "sourcemap": true,
    "target": "esnext"
  }
}
